<%- include('layouts/header') %>

<h1 class="mb-4"><%= pageTitle %></h1>

<div class="row row-cols-1 row-cols-md-3 g-4">
    <% if (products.length === 0) { %>
        <div class="col-12">
            <div class="alert alert-info">Jelenleg nincs megjeleníthető termék.</div>
        </div>
    <% } else { %>
        <% products.forEach(function(product) { %>
            
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm position-relative hover-shrink">

                    <img src="<%= product.imageUrl %>" class="card-img-top p-3" alt="<%= product.name %>" style="height: 200px; width: 100%; object-fit: contain; background-color: #ffffff; border-bottom: 1px solid #eee;">

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold"><%= product.name %></h5>
                        <h6 class="card-subtitle mb-3 text-primary fw-bold"><%= product.price %> Ft</h6>
                        <p class="card-text text-muted small"><%= product.description %></p>

                        <div class="mt-auto">
                            <hr class="my-3 text-muted">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <% if (product.stock > 0) { %>

                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">
                                            <i class="bi bi-check-circle"></i> Raktáron: <%= product.stock %> db
                                        </span>

                                        <% } else { %>

                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">
                                                <i class="bi bi-x-circle"></i> Elfogyott 
                                            </span>

                                            <% } %>
                                        </div>

                                        <form action="/cart/add/<%= product._id %>" method="POST" class="z-3 m-0">
                                            <button type="submit" class="btn btn-primary rounded-pill px-3 shadow-sm" <%= product.stock === 0 ? 'disabled' : '' %>>
                                                <i class="bi bi-cart-plus"></i>
                                            </button>
                                        </form>

                                    </div>
                                </div>
                            </div>
                            <a href="/product/<%= product._id %>" class="stretched-link"></a>
                        </div>
                    </div>

        <% }) %>
    <% } %>
</div>

<%- include('layouts/footer') %>