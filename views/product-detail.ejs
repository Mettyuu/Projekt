<%- include('layouts/header') %>

<div class="row mt-4">
    <div class="col-md-6 mb-4">
        <img src="<%= product.imageUrl %>" 
            class="card-img-top p-3" 
            alt="<%= product.name %>" 
            style="height: 500px; width: 100%; object-fit: contain; background-color: #ffffff; border-bottom: 1px solid #eee;">
    </div>
    
    <div class="col-md-6">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Főoldal</a></li>
                <li class="breadcrumb-item active" aria-current="page"><%= product.category %></li>
            </ol>
        </nav>
        
        <h1 class="display-5 fw-bold"><%= product.name %></h1>
        <h2 class="text-primary mb-4"><%= product.price %> Ft</h2>
        
        <p class="lead"><%= product.description %></p>
        
        <hr class="my-4">
        
        <div class="d-flex align-items-center justify-content-start gap-4 mb-4 mt-4">
    
    <div>
        <span class="text-muted me-2 small">Elérhetőség:</span>
        <% if (product.stock > 0) { %>
            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-6">
                <i class="bi bi-check-circle"></i> Raktáron: <%= product.stock %> db
            </span>
        <% } else { %>
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 fs-6">
                <i class="bi bi-x-circle"></i> Elfogyott
            </span>
        <% } %>
    </div>

    <form action="/cart/add/<%= product._id %>" method="POST" class="m-0">
        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm hover-shrink" <%= product.stock === 0 ? 'disabled' : '' %>>
            <i class="bi bi-cart-plus me-2"></i> Kosárba
        </button>
    </form>

    </div>
        <div class="text-muted small padding mt-3">
            <p class="mb-0"><strong>Feltöltve:</strong> <%= product.createdAt.toLocaleDateString('hu-HU') %></p>
        </div>
        <div class="mt-4 p-2 border rounded bg-light">
            <span class="text-muted small me-3">Adminisztrátori műveletek:</span>

            <a href="/product/<%= product._id %>/edit" class="btn btn-warning btn-sm me-2">
                Termék szerkesztése
            </a>
            
            <form action="/product/<%= product._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Biztosan véglegesen törölni szeretnéd ezt a terméket?');">
                <button type="submit" class="btn btn-danger btn-sm">Termék törlése</button>
            </form>
        </div>
    </div>
</div>

<%- include('layouts/footer') %>